# ── Application ──────────────────────────────────────────────────────────────
APP_NAME="Object Detection API"
APP_VERSION="1.0.0"
DEBUG=false

# ── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── CORS (comma-separated origins) ────────────────────────────────────────────
# Add your frontend URL here
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","http://localhost:3002","http://127.0.0.1:3000","http://127.0.0.1:3001","http://127.0.0.1:3002"]

# ── Model weights ─────────────────────────────────────────────────────────────
# For PyTorch backends — Ultralytics auto-downloads if not found locally
YOLOV8_WEIGHTS=yolov8n.pt
# For YOLOv5: path to local .pt file (preferred) OR hub variant name (yolov5s | yolov5m)
YOLOV5_WEIGHTS=weights/yolov5s.pt

# ── Exported model paths (created by scripts/export_*.py) ────────────────────
YOLOV8_TORCHSCRIPT_PATH=weights/yolov8n.torchscript
YOLOV8_ONNX_PATH=weights/yolov8n.onnx
YOLOV5_TORCHSCRIPT_PATH=weights/yolov5s.torchscript
YOLOV5_ONNX_PATH=weights/yolov5s.onnx

# ── ONNX Runtime execution provider ──────────────────────────────────────────
# Options: CPUExecutionProvider | CUDAExecutionProvider
# Automatically falls back to CPU if CUDA is not available.
ONNX_EXECUTION_PROVIDER=CPUExecutionProvider

# ── Inference defaults ────────────────────────────────────────────────────────
DEFAULT_CONFIDENCE=0.25
DEFAULT_IOU=0.45
DEFAULT_IMAGE_SIZE=640
